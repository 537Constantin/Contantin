// AI Workforce OS — Prisma schema
//
// Generic persistence for the objects users create (workflows, documents,
// graphs). Each row stores the object exactly as the app already uses it, as
// JSON — so the client's localStorage shapes and the database stay in sync with
// no field-by-field mapping. This keeps the database layer small and safe to
// enable incrementally; a richer normalized model can come later.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StoreItem {
  id        String   @id
  scope     String   @default("default")
  kind      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, kind])
}
