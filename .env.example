# ─────────────────────────────────────────────────────────────
# AI Workforce OS — Environment variables
# Copy to `.env` and fill in. None are required to run the demo;
# the app falls back to a fully interactive mock mode without them.
# ─────────────────────────────────────────────────────────────

# AI providers ----------------------------------------------------
# Set OPENAI_API_KEY to switch the chat from demo mode to live streaming.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: used by consultant/analyst agents in production.
ANTHROPIC_API_KEY=

# Database (PostgreSQL) ------------------------------------------
# Required only once you wire up the Prisma persistence layer.
DATABASE_URL="postgresql://user:password@localhost:5432/workforce_os?schema=public"

# Authentication (Clerk) -----------------------------------------
# Optional: leave empty to run in demo mode (no login required).
# Add both keys (free tier at https://clerk.com) to enable real
# account creation, sign-in, password reset and Google/Apple login.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional URL overrides (defaults shown):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Payments (Stripe) ----------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Voice / telephony (e.g. Twilio + Deepgram/ElevenLabs) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_API_KEY=

# App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
