# ─────────────────────────────────────────────────────────────
# AI Workforce OS — Environment variables
# Copy to `.env` and fill in. None are required to run the demo;
# the app falls back to a fully interactive mock mode without them.
# ─────────────────────────────────────────────────────────────

# AI providers ----------------------------------------------------
# Set OPENAI_API_KEY to switch the chat from demo mode to live streaming.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: used by consultant/analyst agents in production.
ANTHROPIC_API_KEY=

# Database (PostgreSQL) ------------------------------------------
# Required only once you wire up the Prisma persistence layer.
DATABASE_URL="postgresql://user:password@localhost:5432/workforce_os?schema=public"

# Authentication (Clerk) -----------------------------------------
# Optional: leave empty to run in demo mode (no login required).
# Add both keys (free tier at https://clerk.com) to enable real
# account creation, sign-in, password reset and Google/Apple login.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional URL overrides (defaults shown):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Payments (Stripe) ----------------------------------------------
# Optional: leave empty to run checkout in demo mode (no real charge).
# Add the secret key (free test mode at https://stripe.com) to go live.
STRIPE_SECRET_KEY=
# Recurring monthly Price IDs for the self-serve plans (Stripe Dashboard →
# Products). Required only for live checkout of that plan.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
# Optional: verifies incoming webhooks at /api/billing/webhook.
STRIPE_WEBHOOK_SECRET=
# Optional: only needed for client-side Stripe.js flows (not the redirect
# checkout used here).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
